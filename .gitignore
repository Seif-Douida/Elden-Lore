# slip in. Keep the folder present (but empty) via .gitkeep if you want the path.
data_pipeline/data/

# Eval — generated benchmark run outputs (reproducible)
backend/eval/results/

# CLI scratch outputs (router.py / pipeline.py --out defaults)
router_output.txt
pipeline_output.txt

