# ── Qdrant (vector DB) ────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=                  # empty for local; set for Qdrant Cloud
QDRANT_HTTPS=false               # true for Qdrant Cloud (TLS)
QDRANT_COLLECTION_NAME=elden_ring

# ── LLM layer (3-tier fallback) ───────────────────────────────────────────────
# Chat/generation tier order (primary first). Unconfigured tiers are skipped.
GEN_TIER_ORDER=gemini,nim,ollama
# Gemini = default chat primary. Enable with a key; try gemini-3-flash for the newest.
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# NIM = chat fallback + router primary. Router MUST support structured output.
NVIDIA_API_KEY=
NIM_MODEL=nvidia/nemotron-3-ultra-550b-a55b
NIM_ROUTER_MODEL=meta/llama-3.1-8b-instruct
# Ollama = optional local last-resort tier.
USE_OLLAMA=false
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=dev                  # dev = permissive CORS + dev-user auth stub; prod = strict
LOG_LEVEL=INFO                   # INFO/DEBUG; JSON structured logs
CORS_ORIGINS=                    # comma-separated prod origins, e.g. https://your.vercel.app

# ── Database (Supabase Postgres) ──────────────────────────────────────────────
# Must use the async driver + Supabase SESSION POOLER host.
DATABASE_URL=postgresql+asyncpg://postgres.<ref>:<pw>@<...>.pooler.supabase.com:5432/postgres

# ── Supabase auth (Phase 3 — not wired yet) ───────────────────────────────────
SUPABASE_URL=
SUPABASE_JWT_SECRET=

# ── Pipeline (offline ingestion) ──────────────────────────────────────────────
WIKI_RATE_LIMIT_SECONDS=1.0      # politeness delay between wiki requests
CHUNK_SIZE=512
CHUNK_OVERLAP=64
