# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=                  # leave empty for local dev

# Gemini (for later — backend phase)
GEMINI_API_KEY=

# Supabase (for later — auth phase)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Pipeline settings
WIKI_RATE_LIMIT_SECONDS=1.0      # politeness delay between requests
QDRANT_COLLECTION_NAME=elden_ring
CHUNK_SIZE=512
CHUNK_OVERLAP=64